{
  "name": "llm-web-context-bridge",
  "version": "1.0.0",
  "description": "A Chrome extension to generate project context prompts for LLMs",
  "keywords": [
    "chrome-extension",
    "llm",
    "prompt",
    "chatgpt",
    "code-assistant",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/llm-web-context-bridge.git"
  },
  "scripts": {
    "build": "vite build --config scripts/build-extension.js",
    "build:extension": "vite build --config scripts/build-extension.js",
    "dev": "vite build --config scripts/build-extension.js --watch",
    "ts-check": "tsc -p tsconfig.json",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "@types/node": "^22.10.5",
    "typescript": "^5.6.0",
    "vite": "^7.2.4"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "pnpm": ">=9.0.0"
  }
}
